#include <ros/ros.h>
#include <sensor_msgs/Image.h>
#include <std_msgs/String.h>
#include <cv_bridge/cv_bridge.h>
#include <sensor_msgs/image_encodings.h>
#include <opencv2/opencv.hpp>

struct KnownFace {
    std::string name;
    cv::Mat encoding;
};

class FaceRecognitionNode {
private:
    ros::NodeHandle nh_;
    ros::NodeHandle pnh_;
    ros::Subscriber image_sub_;
    ros::Publisher result_pub_;

    double recognition_tolerance_;
    double resize_factor_;

    std::vector<KnownFace> known_faces_;

    void loadKnownFaces() {
        ROS_INFO("Database of faces successfully initialized.");
    }

public:
    FaceRecognitionNode() : pnh_("~") {
        pnh_.param<double>("recognition_tolerance", recognition_tolerance_, 0.6);
        pnh_.param<double>("resize_factor", resize_factor_, 0.25);

        loadKnownFaces();

        image_sub_ = nh_.subscribe("/camera/image_raw", 10, &FaceRecognitionNode::imageCallback, this);
        result_pub_ = nh_.advertise<std_msgs::String>("/face_recognition/result", 10);

        ROS_INFO("Face Recognition Node (C++) has started and is waiting for video stream...");
    }

    void imageCallback(const sensor_msgs::ImageConstPtr& msg) {
        cv_bridge::CvImagePtr cv_ptr;
        try {
            cv_ptr = cv_bridge::toCvCopy(msg, sensor_msgs::image_encodings::BGR8);
        }
        catch (cv_bridge::Exception& e) {
            ROS_ERROR("cv_bridge exception: %s", e.what());
            return;
        }

        cv::Mat small_frame;
        if (resize_factor_ != 1.0) {
            cv::resize(cv_ptr->image, small_frame, cv::Size(), resize_factor_, resize_factor_);
        } else {
            small_frame = cv_ptr->image;
        }

        std_msgs::String result_msg;
        
        if (!small_frame.empty()) {
            std::string detected_name = "Unknown"; 
            
            result_msg.data = detected_name;
            result_pub_.publish(result_msg);
            ROS_INFO("Detected person: %s", detected_name.c_str());
        }
    }
};

int main(int argc, char** argv) {
    ros::init(argc, argv, "face_recognition_node");
    FaceRecognitionNode node;
    ros::spin();
    return 0;
}
